# RescueNet backend environment variables.
# Copy to `.env` and fill in real values. Never commit the real .env file.

# Runtime
NODE_ENV=development
PORT=5001

# Database
MONGO_URI=mongodb://localhost:27017/disasterDB

# Auth
# Use a long, random string in production, e.g.
#   openssl rand -hex 64
JWT_SECRET=replace-me-with-a-long-random-string

# Logging
LOG_LEVEL=info
