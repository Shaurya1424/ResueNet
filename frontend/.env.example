# RescueNet frontend environment variables.
# Copy to `.env` (or `.env.development.local` / `.env.production.local`).
# All variables MUST start with REACT_APP_ to be exposed to the client bundle.

# Base URL of the backend API. When running with docker-compose the
# frontend container proxies /api to the backend, so "/api" is enough.
# When running locally without the proxy, use the host+port explicitly.
REACT_APP_API_URL=http://localhost:5001/api
