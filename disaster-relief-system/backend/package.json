{
  "name": "rescuenet-backend",
  "version": "1.0.0",
  "description": "Backend API for RescueNet Disaster Relief Resource Management System",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "cross-env NODE_ENV=test JWT_SECRET=test-secret jest --runInBand",
    "test:watch": "cross-env NODE_ENV=test JWT_SECRET=test-secret jest --runInBand --watch",
    "test:coverage": "cross-env NODE_ENV=test JWT_SECRET=test-secret jest --runInBand --coverage",
    "lint": "eslint ."
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-validator": "^7.2.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "mongoose": "^8.6.1",
    "prom-client": "^15.1.3",
    "winston": "^3.14.2"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.1.2",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  }
}
